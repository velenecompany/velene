# Database (same for both platforms)
DATABASE_URL=postgresql://vela_user:STRONG_PASSWORD@db.yourhost.com:5432/vela_prod

# JWT
JWT_SECRET=replace_with_64_char_random_string

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# App
NEXT_PUBLIC_APP_URL=https://velawear.com
NODE_ENV=production

# Email (Resend or SMTP)
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@velawear.com
